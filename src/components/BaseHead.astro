---
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image = FallbackImage } = Astro.props;

const ogImage = image.src.includes('blog-placeholder-1') 
	? 'https://images.unsplash.com/photo-1618401471353-b98afee0b2eb?w=1200&h=630&fit=crop&q=80' 
	: new URL(image.src, Astro.url).href;

// Formats a clean JSON-LD object for Google to pull structured code rich results
const techArticleSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "TechArticle",
	"headline": title,
	"description": description,
	"proficienciesRequired": "Developer",
	"publisher": {
		"@type": "Organization",
		"name": "ErrorLedger",
		"url": "https://errorledger.com"
	}
});

// Formats a clean Breadcrumb List to display a safe category tree inside Google Search instead of raw URLs
const breadcrumbSchema = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": "https://errorledger.com"
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Blog",
			"item": "https://errorledger.com/blog"
		}
	]
});
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-atkinson" preload />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />

<!-- Invisible Structured Search Schemas Injection -->
<script type="application/ld+json" set:html={techArticleSchema}></script>
<script type="application/ld+json" set:html={breadcrumbSchema}></script>

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogImage} />

<!-- Google AdSense -->
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9920262252083841" crossorigin="anonymous"></script>

<!-- Dark Mode Persistence Script -->
<script is:inline>
  const theme = (() => {
    if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
      return localStorage.getItem('theme');
    }
    if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
      return 'dark';
    }
    return 'light';
  })();
  if (theme === 'dark') {
    document.documentElement.classList.add('dark');
  } else {
    document.documentElement.classList.remove('dark');
  }
</script>

<!-- Comprehensive Dark Mode Global Overrides -->
<style is:global>
  html.dark {
    background: #0f172a !important;
    background-image: none !important;
    color: #e2e8f0 !important;
  }
  html.dark body, 
  html.dark main, 
  html.dark article, 
  html.dark .prose {
    background: #0f172a !important;
    background-image: none !important;
    color: #e2e8f0 !important;
  }
  html.dark header {
    background-color: #1e293b !important;
    background-image: none !important;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4) !important;
  }
  
  /* Formats headers, labels, and grid headings to high contrast white */
  html.dark h1, html.dark h2, html.dark h3, html.dark h4, html.dark h5, html.dark h6,
  html.dark th, html.dark dt, html.dark strong {
    color: #f8fafc !important;
  }
  
  /* Sets body text, code explanations, and grid text fields to light grey */
  html.dark p, html.dark li, html.dark time, html.dark td, html.dark dd, html.dark div:not([style*="color"]) {
    color: #cbd5e1 !important;
  }
  
  /* Specific styling resets for lists and navigation items */
  html.dark .internal-links a {
    color: #cbd5e1 !important;
  }
  html.dark .internal-links a.active {
    color: #f8fafc !important;
  }
  html.dark ul li a h4 {
    color: #f8fafc !important;
  }

  /* Inline styles component override fallback */
  html.dark [style*="color: #1e293b"], 
  html.dark [style*="color: rgb(var(--black))"] {
    color: #cbd5e1 !important;
  }

  /* Inline syntax block handling */
  html.dark pre, html.dark code {
    background-color: #1e293b !important;
    color: #f1f5f9 !important;
  }
  html.dark footer {
    background-color: #0f172a !important;
    color: #94a3b8 !important;
    background-image: none !important;
  }
  html.dark .prose a {
    color: #38bdf8 !important;
  }
</style>