---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} ErrorLedger. All rights reserved.
	<style>
		footer {
			padding: 2rem 1rem 3rem 1rem;
			text-align: center;
			font-size: 0.9rem;
			color: rgb(var(--gray));
			border-top: 1px solid #e4e4e7;
			margin-top: auto;
		}
		:global(html.dark) footer {
			border-top-color: #334155;
			color: #94a3b8;
		}
	</style>
</footer>