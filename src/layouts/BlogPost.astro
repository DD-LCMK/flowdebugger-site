---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, meta_title, description, pubDate, tags = [] } = Astro.props;

// Prioritize your optimized, click-friendly search title
const seoTitle = meta_title || title;
---

<html lang="en">
	<head>
		<BaseHead title={seoTitle} description={description} />
		<style>
			main { width: calc(100% - 2rem); max-width: 720px; margin: 0 auto; padding: 3em 1rem; }
			.prose { color: #2d3748; line-height: 1.75; font-size: 1.1rem; }
			.prose h1 { font-size: 2.25em; margin-top: 0; margin-bottom: 0.8em; color: #1a202c; line-height: 1.2; }
			.prose h2 { font-size: 1.5em; margin-top: 1.5em; margin-bottom: 0.5em; color: #2d3748; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.3em; }
			
			/* Global overrides to target elements inside the markdown <slot /> safely */
			.prose :global(pre) { 
				position: relative !important; 
				padding: 2.75rem 1rem 1.25rem 1rem !important; 
				border-radius: 8px !important; 
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05) !important;
			}
			.prose :global(code) { background-color: #f7fafc; padding: 0.2em 0.4em; border-radius: 4px; font-size: 0.9em; color: #e53e3e; font-family: monospace; }
			.prose :global(pre code) { background-color: transparent !important; padding: 0 !important; color: inherit !important; font-size: inherit !important; }
			
			/* Premium Modern Code Block Copy Button Styles */
			.prose :global(.code-copy-btn) {
				position: absolute !important;
				top: 0.75rem !important;
				right: 0.75rem !important;
				background: #ffffff !important;
				border: 1px solid #e2e8f0 !important;
				padding: 0.35rem 0.65rem !important;
				border-radius: 6px !important;
				font-size: 0.75rem !important;
				font-family: system-ui, -apple-system, sans-serif !important;
				cursor: pointer !important;
				color: #475569 !important;
				font-weight: 600 !important;
				transition: all 0.15s ease-in-out !important;
				opacity: 0; /* Hidden until container hover */
				box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05) !important;
				z-index: 10 !important;
			}
			
			/* Show copy button clearly when hovering over the code snippet box */
			.prose :global(pre:hover .code-copy-btn) { 
				opacity: 1 !important; 
			}
			
			.prose :global(.code-copy-btn:hover) { 
				background: #f8fafc !important; 
				border-color: #cbd5e1 !important;
				color: #0f172a !important;
				transform: translateY(-1px);
			}

			.prose :global(table) { width: 100%; margin: 2em 0; border-collapse: collapse; }
			.prose :global(th) { background-color: #f7fafc; padding: 10px; border-bottom: 2px solid #edf2f7; text-align: left; }
			.prose :global(td) { padding: 10px; border-bottom: 1px solid #edf2f7; }
			
			/* Share Actions Styles */
			.meta-wrapper { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px dashed #e2e8f0; flex-wrap: wrap; gap: 1rem; }
			.date { color: #718096; font-size: 0.95rem; }
			.share-actions { display: flex; gap: 0.5rem; }
			.share-btn { background: #ffffff; border: 1px solid #cbd5e1; padding: 0.4rem 0.75rem; border-radius: 6px; font-size: 0.85rem; cursor: pointer; display: inline-flex; align-items: center; gap: 0.25rem; color: #334155; text-decoration: none; font-weight: 500; }
			.share-btn:hover { background: #f8fafc; border-color: #94a3b8; color: #0f172a; }

			/* 3-Tier Tag Layout badge row */
			.tag-container { display: flex; gap: 0.5rem; margin-bottom: 2rem; flex-wrap: wrap; }
			.tag-badge { font-size: 0.75rem; font-weight: 700; background: #f1f5f9; color: #475569; padding: 0.15rem 0.45rem; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.025em; }

			/* Premium Dark Mode Styles */
			:global(html.dark) .prose { color: #cbd5e1; }
			:global(html.dark) .prose h1, :global(html.dark) .prose h2 { color: #f8fafc; }
			:global(html.dark) .prose :global(th) { background-color: #1e293b; border-bottom-color: #334155; }
			:global(html.dark) .prose :global(td) { border-bottom-color: #334155; }
			:global(html.dark) .meta-wrapper { border-bottom-color: #334155; }
			:global(html.dark) .tag-badge { background: #334155; color: #cbd5e1; }
			:global(html.dark) .share-btn { background: #1e293b; border-color: #334155; color: #cbd5e1; }
			:global(html.dark) .share-btn:hover { background: #273549; border-color: #475569; color: #f8fafc; }

			:global(html.dark) .prose :global(.code-copy-btn) {
				background: #1e293b !important;
				border-color: #334155 !important;
				color: #cbd5e1 !important;
				box-shadow: 0 1px 2px rgba(0, 0, 0, 0.3) !important;
			}
			:global(html.dark) .prose :global(.code-copy-btn:hover) {
				background: #273549 !important;
				border-color: #475569 !important;
				color: #f8fafc !important;
			}
			:global(html.dark) .prose :global(pre) {
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3) !important;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="meta-wrapper">
						{pubDate && (
							<div class="date">
								<FormattedDate date={pubDate} />
							</div>
						)}
						<div class="share-actions">
							<!-- X Share Intent -->
							<a href={`https://x.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" class="share-btn">
								Share on X
							</a>
							<!-- Copy Link Action -->
							<button id="copy-link-btn" class="share-btn">
								Copy Link
							</button>
						</div>
					</div>

					<!-- Visual 3-Tier Tag Ledger Row -->
					<div class="tag-container">
						{tags.map((tag) => (
							<span class="tag-badge">
								{tag}
							</span>
						))}
					</div>

					<slot />
				</div>
			</article>
		</main>
		<Footer />

		<script>
			// Handle article URL sharing clipboard actions
			const copyBtn = document.getElementById('copy-link-btn');
			if (copyBtn) {
				copyBtn.addEventListener('click', () => {
					navigator.clipboard.writeText(window.location.href);
					const originalText = copyBtn.textContent;
					copyBtn.textContent = 'Copied!';
					setTimeout(() => {
						copyBtn.textContent = originalText;
					}, 2000);
				});
			}

			// Dynamically locate markdown pre containers and attach the modern copy utility
			const codeBlocks = document.querySelectorAll('.prose pre');
			codeBlocks.forEach((block) => {
				const button = document.createElement('button');
				button.className = 'code-copy-btn';
				button.textContent = 'Copy';
				block.appendChild(button);

				button.addEventListener('click', async () => {
					const codeElement = block.querySelector('code');
					const textToCopy = codeElement ? codeElement.innerText : (block as HTMLElement).innerText;
					
					try {
						await navigator.clipboard.writeText(textToCopy);
						button.textContent = 'Copied!';
						setTimeout(() => {
							button.textContent = 'Copy';
						}, 2000);
					} catch (err) {
						console.error('Failed to copy code snippet text: ', err);
					}
				});
			});
		</script>
	</body>
</html>