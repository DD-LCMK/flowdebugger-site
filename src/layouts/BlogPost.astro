---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, meta_title, description, pubDate, tags = [] } = Astro.props;

const seoTitle = meta_title || title;

// 1. Fetch and sort collection to establish relative node tracking mapping
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => {
	const dateA = a.data.pubDate ? new Date(a.data.pubDate).valueOf() : 0;
	const dateB = b.data.pubDate ? new Date(b.data.pubDate).valueOf() : 0;
	return dateB - dateA;
});

// 2. Identify neighbors based on the unique document record title match
const currentIndex = sortedPosts.findIndex(post => post.data.title === title);
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
---

<html lang="en">
	<head>
		<BaseHead title={seoTitle} description={description} />
		<style>
			main { width: calc(100% - 2rem); max-width: 960px; margin: 0 auto; padding: 2em 1rem; }
			
			.post-layout-grid {
				display: grid;
				grid-template-columns: 1fr;
				gap: 3rem;
				align-items: start;
			}

			@media (min-width: 1024px) {
				.post-layout-grid.has-sidebar {
					grid-template-columns: 1fr 260px; /* Split column grid tracking configuration */
				}
			}

			/* Structural Telemetry Sidebar Panel */
			.sidebar-wrapper {
				display: none;
			}
			@media (min-width: 1024px) {
				.post-layout-grid.has-sidebar .sidebar-wrapper {
					display: block;
					position: sticky;
					top: 5.5rem;
					height: fit-content;
					max-height: calc(100vh - 7rem);
					overflow-y: auto;
					background: #f8fafc;
					border: 1px solid #e2e8f0;
					border-radius: 8px;
					padding: 1.25rem;
				}
			}

			.toc-title {
				font-family: ui-monospace, monospace;
				font-size: 0.72rem;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: #64748b;
				margin-bottom: 0.75rem;
				border-bottom: 1px solid #e2e8f0;
				padding-bottom: 0.5rem;
			}
			.toc-list {
				list-style: none;
				padding: 0;
				margin: 0 0 1.5rem 0;
			}
			.toc-item {
				margin-bottom: 0.5rem;
				font-size: 0.85rem;
				line-height: 1.4;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			.toc-item a {
				color: #475569;
				text-decoration: none;
				transition: color 0.15s ease;
			}
			.toc-item:hover a { color: #ef4444; }
			.toc-item.active a { color: #ef4444; font-weight: 700; }

			.toc-depth-h3 {
				padding-left: 0.75rem;
				font-size: 0.8rem;
				border-left: 1px solid #e2e8f0;
				margin-left: 0.25rem;
			}

			/* Adjacent Records Navigation block inside the sidebar box */
			.adjacent-bus-panel {
				margin-top: 1.5rem;
				border-top: 1px dashed #e2e8f0;
				padding-top: 1rem;
			}
			.nav-node-link {
				display: block;
				text-decoration: none;
				margin-bottom: 0.75rem;
			}
			.nav-node-label {
				display: block;
				font-family: ui-monospace, monospace;
				font-size: 0.68rem;
				font-weight: 700;
				color: #94a3b8;
				text-transform: uppercase;
				margin-bottom: 0.15rem;
			}
			.nav-node-title {
				display: block;
				font-size: 0.82rem;
				color: #475569;
				line-height: 1.3;
				font-weight: 600;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
				transition: color 0.15s ease;
			}
			.nav-node-link:hover .nav-node-title { color: #ef4444; }

			.prose { color: #2d3748; line-height: 1.75; font-size: 1.1rem; }
			.prose h1 { font-size: 2.25em; margin-top: 0; margin-bottom: 0.8em; color: #1a202c; line-height: 1.2; }
			.prose h2 { font-size: 1.5em; margin-top: 1.5em; margin-bottom: 0.5em; color: #2d3748; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.3em; scroll-margin-top: 6.5rem; }
			.prose :global(h3) { font-size: 1.2em; margin-top: 1.3em; margin-bottom: 0.4em; color: #2d3748; font-weight: 700; scroll-margin-top: 6.5rem; }
			
			.prose :global(pre) { position: relative !important; padding: 2.75rem 1rem 1.25rem 1rem !important; border-radius: 8px !important; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05) !important; }
			.prose :global(code) { background-color: #f7fafc; padding: 0.2em 0.4em; border-radius: 4px; font-size: 0.9em; color: #e53e3e; font-family: monospace; }
			.prose :global(pre code) { background-color: transparent !important; padding: 0 !important; color: inherit !important; font-size: inherit !important; }
			
			.prose :global(.code-copy-btn) {
				position: absolute !important;
				top: 0.75rem !important;
				right: 0.75rem !important;
				background: #ffffff !important;
				border: 1px solid #e2e8f0 !important;
				padding: 0.35rem 0.65rem !important;
				border-radius: 6px !important;
				font-size: 0.75rem !important;
				font-family: system-ui, -apple-system, sans-serif !important;
				cursor: pointer !important;
				color: #475569 !important;
				font-weight: 600 !important;
				transition: all 0.15s ease-in-out !important;
				opacity: 0;
				box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05) !important;
				z-index: 10 !important;
			}
			.prose :global(pre:hover .code-copy-btn) { opacity: 1 !important; }
			.prose :global(.code-copy-btn:hover) { background: #f8fafc !important; border-color: #cbd5e1 !important; color: #0f172a !important; transform: translateY(-1px); }

			.prose :global(table) { width: 100%; margin: 2em 0; border-collapse: collapse; }
			.prose :global(th) { background-color: #f7fafc; padding: 10px; border-bottom: 2px solid #edf2f7; text-align: left; }
			.prose :global(td) { padding: 10px; border-bottom: 1px solid #edf2f7; }
			
			.meta-wrapper { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px dashed #e2e8f0; flex-wrap: wrap; gap: 1rem; }
			.date { color: #718096; font-size: 0.95rem; }
			.share-actions { display: flex; gap: 0.5rem; }
			.share-btn { background: #ffffff; border: 1px solid #cbd5e1; padding: 0.4rem 0.75rem; border-radius: 6px; font-size: 0.85rem; cursor: pointer; display: inline-flex; align-items: center; gap: 0.25rem; color: #334155; text-decoration: none; font-weight: 500; }
			.share-btn:hover { background: #f8fafc; border-color: #94a3b8; color: #0f172a; }

			.tag-container { display: flex; gap: 0.5rem; margin-bottom: 2rem; flex-wrap: wrap; }
			.tag-badge { font-size: 0.75rem; font-weight: 700; background: #f1f5f9; color: #475569; padding: 0.15rem 0.45rem; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.025em; }

			/* Premium Dark Mode Interfacing Configuration */
			:global(html.dark) .prose { color: #cbd5e1; }
			:global(html.dark) .prose h1, :global(html.dark) .prose h2, :global(html.dark) .prose :global(h3) { color: #f8fafc; }
			:global(html.dark) .prose :global(th) { background-color: #1e293b; border-bottom-color: #334155; }
			:global(html.dark) .prose :global(td) { border-bottom-color: #334155; }
			:global(html.dark) .meta-wrapper { border-bottom-color: #334155; }
			:global(html.dark) .tag-badge { background: #334155; color: #cbd5e1; }
			:global(html.dark) .share-btn { background: #1e293b; border-color: #334155; color: #cbd5e1; }
			:global(html.dark) .share-btn:hover { background: #273549; border-color: #475569; color: #f8fafc; }

			:global(html.dark) .sidebar-wrapper { background: #1e293b; border-color: #334155; }
			:global(html.dark) .toc-title { color: #cbd5e1; border-bottom-color: #334155; }
			:global(html.dark) .toc-item a { color: #cbd5e1; }
			:global(html.dark) .toc-item:hover a { color: #ef4444; }
			:global(html.dark) .toc-item.active a { color: #ef4444; }
			:global(html.dark) .toc-depth-h3 { border-left-color: #334155; }
			:global(html.dark) .adjacent-bus-panel { border-top-color: #334155; }
			:global(html.dark) .nav-node-title { color: #cbd5e1; }
			:global(html.dark) .nav-node-link:hover .nav-node-title { color: #ef4444; }

			:global(html.dark) .prose :global(.code-copy-btn) { background: #1e293b !important; border-color: #334155 !important; color: #cbd5e1 !important; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.3) !important; }
			:global(html.dark) .prose :global(.code-copy-btn:hover) { background: #273549 !important; border-color: #475569 !important; color: #f8fafc !important; }
			:global(html.dark) .prose :global(pre) { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3) !important; }
		</style>
	</head>

	<body>
		<Header />
		<main>
			<!-- Layout grid defaults to tracking structure wrapper, code auto-collapses this via JS if empty -->
			<div class="post-layout-grid has-sidebar" id="layout-grid-frame">
				<!-- Main Body Content Area -->
				<article>
					<div class="prose">
						<div class="meta-wrapper">
							{pubDate && (
								<div class="date">
									<FormattedDate date={pubDate} />
								</div>
							)}
							<div class="share-actions">
								<a href={`https://x.com/intent/tweet?url=${encodeURIComponent(Astro.url.href)}&text=${encodeURIComponent(title)}`} target="_blank" rel="noopener noreferrer" class="share-btn">
									Share on X
								</a>
								<button id="copy-link-btn" class="share-btn">
									Copy Link
								</button>
							</div>
						</div>

						<div class="tag-container">
							{tags.map((tag) => (
								<span class="tag-badge">
									{tag}
								</span>
							))}
						</div>

						<slot />
					</div>
				</article>

				<!-- Structured Right-Aligned Telemetry Panel Container -->
				<aside class="sidebar-wrapper">
					<div class="toc-title">Telemetry Matrix</div>
					<ul class="toc-list" id="dynamic-toc-bus"></ul>

					<!-- Adjacent Paging Node Subpanel -->
					<div class="adjacent-bus-panel">
						<div class="toc-title">Adjacent Logs</div>
						
						{nextPost && (
							<a href={`/blog/${nextPost.data.shortenedSlug}/`} class="nav-node-link">
								<span class="nav-node-label">← Next Record</span>
								<span class="nav-node-title">{nextPost.data.title}</span>
							</a>
						)}
						
						{prevPost && (
							<a href={`/blog/${prevPost.data.shortenedSlug}/`} class="nav-node-link">
								<span class="nav-node-label">Previous Record →</span>
								<span class="nav-node-title">{prevPost.data.title}</span>
							</a>
						)}
					</div>
				</aside>
			</div>
		</main>
		<Footer />

		<script lang="ts">
			// Handle article URL sharing clipboard actions
			const copyBtn = document.getElementById('copy-link-btn');
			if (copyBtn) {
				copyBtn.addEventListener('click', () => {
					navigator.clipboard.writeText(window.location.href);
					const originalText = copyBtn.textContent;
					copyBtn.textContent = 'Copied!';
					setTimeout(() => {
						copyBtn.textContent = originalText;
					}, 2000);
				});
			}

			// Attach copy utilities to code blocks
			const codeBlocks = document.querySelectorAll('.prose pre');
			codeBlocks.forEach((block) => {
				const button = document.createElement('button');
				button.className = 'code-copy-btn';
				button.textContent = 'Copy';
				block.appendChild(button);

				button.addEventListener('click', async () => {
					const codeElement = block.querySelector('code');
					const textToCopy = codeElement ? codeElement.innerText : (block as HTMLElement).innerText;
					
					try {
						await navigator.clipboard.writeText(textToCopy);
						button.textContent = 'Copied!';
						setTimeout(() => {
							button.textContent = 'Copy';
						}, 2000);
					} catch (err) {
						console.error('Failed to copy code snippet text: ', err);
					}
				});
			});

			// --- TIMING-SAFE SIDEBAR RENDER ENGINE WITH AUTO-COLLAPSE FOR GENERAL PAGES ---
			function buildTelemetryInterface() {
				const targetContainer = document.getElementById('dynamic-toc-bus');
				const contentHeadings = document.querySelectorAll('.prose h2, .prose h3');
				const layoutFrame = document.getElementById('layout-grid-frame');

				// If no metric headings are found (About/Contact pages), collapse layout structure back to uniform width
				if (contentHeadings.length === 0) {
					if (layoutFrame) {
						layoutFrame.classList.remove('has-sidebar');
					}
					return;
				}
				
				if (targetContainer) {
					targetContainer.innerHTML = ''; // Sanitize container box
					
					contentHeadings.forEach((heading, idx) => {
						if (!heading.id) {
							const slug = heading.textContent
								?.toLowerCase()
								.replace(/[^a-z0-9]+/g, '-')
								.replace(/(^-|-$)/g, '') || `metric-${idx}`;
							heading.id = slug;
						}

						const li = document.createElement('li');
						li.className = `toc-item toc-depth-${heading.tagName.toLowerCase()}`;
						li.dataset.targetId = heading.id;

						const anchor = document.createElement('a');
						anchor.href = `#${heading.id}`;
						anchor.textContent = heading.textContent || 'Telemetry Node';

						li.appendChild(anchor);
						targetContainer.appendChild(li);
					});

					const observerOptions = {
						root: null,
						rootMargin: '-10% 0px -70% 0px',
						threshold: 0
					};

					let activelyIntersectingIds: string[] = [];

					const trackingObserver = new IntersectionObserver((entries) => {
						entries.forEach((entry) => {
							const elementId = entry.target.id;
							if (entry.isIntersecting) {
								if (!activelyIntersectingIds.includes(elementId)) {
									activelyIntersectingIds.push(elementId);
								}
							} else {
								activelyIntersectingIds = activelyIntersectingIds.filter(id => id !== elementId);
							}
						});

						const activeId = activelyIntersectingIds[activelyIntersectingIds.length - 1] || targetContainer.querySelector('.toc-item')?.getAttribute('data-target-id');
						
						if (activeId) {
							document.querySelectorAll('#dynamic-toc-bus .toc-item').forEach((item) => {
								const htmlItem = item as HTMLElement;
								htmlItem.classList.toggle('active', htmlItem.dataset.targetId === activeId);
							});
						}
					}, observerOptions);

					contentHeadings.forEach((el) => trackingObserver.observe(el));
				}
			}

			// Race-condition fallback: Execute instantly if layout DOM is already settled
			if (document.readyState === 'loading') {
				window.addEventListener('DOMContentLoaded', buildTelemetryInterface);
			} else {
				buildTelemetryInterface();
			}
		</script>
	</body>
</html>